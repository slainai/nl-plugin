{
  "_comment": [
    "Source of truth for the 'main' branch ruleset on slainai/nl-plugin.",
    "Apply: gh api repos/slainai/nl-plugin/rulesets -X POST --input .github/rulesets/main-protection.json",
    "Update: gh api repos/slainai/nl-plugin/rulesets/<id> -X PUT --input .github/rulesets/main-protection.json",
    "List:  gh api repos/slainai/nl-plugin/rulesets",
    "Required status check 'context' values must equal a job name that GitHub has seen at least once."
  ],
  "name": "main protection",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["~DEFAULT_BRANCH"],
      "exclude": []
    }
  },
  "bypass_actors": [
    { "actor_type": "OrganizationAdmin", "bypass_mode": "always" },
    { "actor_id": 5, "actor_type": "RepositoryRole", "bypass_mode": "always" }
  ],
  "rules": [
    { "type": "deletion" },
    { "type": "non_fast_forward" },
    { "type": "required_linear_history" },
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 0,
        "dismiss_stale_reviews_on_push": false,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_review_thread_resolution": false,
        "allowed_merge_methods": ["squash"]
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "do_not_enforce_on_create": false,
        "required_status_checks": [
          { "context": "lint" },
          { "context": "validate" },
          { "context": "bump-required" }
        ]
      }
    }
  ]
}
